# ============================================================
# TradingBotV2 — Environment Configuration
# Copy this file to .env and fill in your real values
# Location: C:\TradingBotV2\.env
# ============================================================

# ── Account ──────────────────────────────────────────────────
ACCOUNT_BALANCE=10000
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_TRADES=6
MAX_PORTFOLIO_HEAT=30.0
DAILY_LOSS_LIMIT=3.0
WEEKLY_LOSS_LIMIT=6.0

# ── MT5 — Pepperstone ─────────────────────────────────────────
# Login: your MT5 account number (from Pepperstone welcome email)
# Password: your MT5 password
# Server: use Pepperstone-Demo for demo, Pepperstone-Edge-Live for live
MT5_LOGIN=12345678
MT5_PASSWORD=YourMT5PasswordHere
MT5_SERVER=Pepperstone-Demo

# ── Binance Futures Testnet ───────────────────────────────────
# Get keys from: https://testnet.binancefuture.com
# → Log in → API Management → Create API Key
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_TESTNET=true

# ── Telegram ─────────────────────────────────────────────────
# See TELEGRAM_SETUP section in README_DEPLOY.md
# BOT_TOKEN: from @BotFather
# CHAT_ID: your personal chat ID (see setup instructions)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=987654321

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Storage ───────────────────────────────────────────────────
DATA_DIR=C:\TradingBotV2\data

# ── ML ────────────────────────────────────────────────────────
ML_MIN_TRADES_TO_TRAIN=50
