# ── TradingBotV2 environment variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Account / risk ────────────────────────────────────────────────────────────
ACCOUNT_BALANCE=10000          # Starting account balance in USD
RISK_PER_TRADE_PCT=1.0         # Risk per trade as a % of account balance
DAILY_LOSS_LIMIT=3.0           # Max daily loss as a % of account balance (circuit-breaker)
MAX_OPEN_TRADES=6              # Hard cap on concurrent open paper trades
MAX_PORTFOLIO_HEAT=30.0        # Max total open risk as a % of account balance

# ── Binance Futures ───────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true           # Set to false for live Binance Futures

# ── MetaTrader 5 (leave blank on Linux / VPS — MT5 is Windows-only) ───────────
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=

# ── Telegram alerts ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
